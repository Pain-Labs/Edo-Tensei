{
  "name": "edo-tensei",
  "displayName": "Edo Tensei",
  "description": "%extension.description%",
  "version": "1.2.0",
  "publisher": "Pain-Labs",
  "icon": "docs/assets/edo_tensei_logo_128.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pain-Labs/Edo-Tensei"
  },
  "bugs": {
    "url": "https://github.com/Pain-Labs/Edo-Tensei/issues"
  },
  "homepage": "https://github.com/Pain-Labs/Edo-Tensei#readme",
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "history",
    "handoff",
    "claude",
    "windsurf",
    "cursor",
    "antigravity",
    "copilot",
    "mcp",
    "model context protocol"
  ],
  "engines": {
    "vscode": "^1.79.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:sessionHandoffView",
    "onCommand:edoTensei.scanAllIdes",
    "onCommand:edoTensei.generateAgentSkill"
  ],
  "contributes": {
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "edoTensei.promptLanguage": {
          "type": "string",
          "enum": [
            "English",
            "Traditional Chinese",
            "Simplified Chinese",
            "Japanese",
            "Korean"
          ],
          "default": "English",
          "description": "%config.promptLanguage.description%"
        },
        "edoTensei.handoffMode": {
          "type": "string",
          "enum": [
            "path",
            "fullText"
          ],
          "enumDescriptions": [
            "%config.handoffMode.pathDescription%",
            "%config.handoffMode.fullTextDescription%"
          ],
          "default": "path",
          "description": "%config.handoffMode.description%"
        },
        "edoTensei.customScanPaths": {
          "type": "object",
          "default": {
            "claude": [],
            "windsurf": [],
            "cursor": [],
            "copilot": [],
            "kiro": [],
            "antigravity": []
          },
          "description": "%config.customScanPaths.description%"
        },
        "edoTensei.lazyLoadMessages": {
          "type": "boolean",
          "default": true,
          "description": "%config.lazyLoadMessages.description%"
        },
        "edoTensei.mcpConfig.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.mcpConfig.enabled.description%"
        },
        "edoTensei.maxSessionsPerIde": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 2000,
          "description": "%config.maxSessionsPerIde.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "edoTenseiContainer",
          "title": "%viewContainer.title%",
          "icon": "docs/assets/edo_tensei_sidebar.svg"
        }
      ]
    },
    "views": {
      "edoTenseiContainer": [
        {
          "id": "sessionHandoffView",
          "name": "%view.sessions.name%",
          "icon": "docs/assets/edo_tensei_sidebar.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sessionHandoffView",
        "contents": "%view.welcome%"
      }
    ],
    "commands": [
      {
        "command": "edoTensei.resurrectSession",
        "title": "%command.resurrectSession.title%",
        "category": "Edo Tensei",
        "icon": "$(sparkle)"
      },
      {
        "command": "edoTensei.copyHandoffPrompt",
        "title": "%command.copyHandoffPrompt.title%",
        "category": "Edo Tensei",
        "icon": "$(copy)"
      },
      {
        "command": "edoTensei.openSessionFile",
        "title": "%command.openSessionFile.title%",
        "category": "Edo Tensei",
        "icon": "$(file-code)"
      },
      {
        "command": "edoTensei.scanAllIdes",
        "title": "%command.scanAllIdes.title%",
        "category": "Edo Tensei",
        "icon": "$(zap)"
      },
      {
        "command": "edoTensei.exportAllSessions",
        "title": "%command.exportAllSessions.title%",
        "category": "Edo Tensei",
        "icon": "$(save-all)"
      },
      {
        "command": "edoTensei.exportSession",
        "title": "%command.exportSession.title%",
        "category": "Edo Tensei",
        "icon": "$(save)"
      },
      {
        "command": "edoTensei.previewRawSession",
        "title": "%command.previewRawSession.title%",
        "category": "Edo Tensei",
        "icon": "$(eye)"
      },
      {
        "command": "edoTensei.viewParsedSession",
        "title": "%command.viewParsedSession.title%",
        "category": "Edo Tensei",
        "icon": "$(open-preview)"
      },
      {
        "command": "edoTensei.copyRawPath",
        "title": "%command.copyRawPath.title%",
        "category": "Edo Tensei",
        "icon": "$(link)"
      },
      {
        "command": "edoTensei.openSettings",
        "title": "%command.openSettings.title%",
        "category": "Edo Tensei",
        "icon": "$(settings-gear)"
      },
      {
        "command": "edoTensei.generateAgentSkill",
        "title": "%command.generateAgentSkill.title%",
        "category": "Edo Tensei",
        "icon": "$(hubot)"
      },
      {
        "command": "edoTensei.copyReferencePrompt",
        "title": "%command.copyReferencePrompt.title%",
        "category": "Edo Tensei",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "edoTensei.copyContextPrompt",
        "title": "%command.copyContextPrompt.title%",
        "category": "Edo Tensei",
        "icon": "$(symbol-string)"
      },
      {
        "command": "edoTensei.showMcpConfig",
        "title": "%command.showMcpConfig.title%",
        "category": "Edo Tensei",
        "icon": "$(server-environment)",
        "enablement": "config.edoTensei.mcpConfig.enabled"
      },
      {
        "command": "edoTensei.refreshIde",
        "title": "%command.refreshIde.title%",
        "category": "Edo Tensei",
        "icon": "$(refresh)"
      },
      {
        "command": "edoTensei.loadMoreSessions",
        "title": "%command.loadMoreSessions.title%",
        "category": "Edo Tensei"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "edoTensei.scanAllIdes",
          "when": "view == sessionHandoffView",
          "group": "navigation@1"
        },
        {
          "command": "edoTensei.exportAllSessions",
          "when": "view == sessionHandoffView",
          "group": "navigation@2"
        },
        {
          "command": "edoTensei.openSettings",
          "when": "view == sessionHandoffView",
          "group": "navigation@99"
        },
        {
          "command": "edoTensei.generateAgentSkill",
          "when": "view == sessionHandoffView",
          "group": "navigation@98"
        },
        {
          "command": "edoTensei.showMcpConfig",
          "when": "view == sessionHandoffView && config.edoTensei.mcpConfig.enabled",
          "group": "navigation@97"
        }
      ],
      "view/item/context": [
        {
          "command": "edoTensei.refreshIde",
          "when": "view == sessionHandoffView && viewItem == ideParentItem",
          "group": "inline@1"
        },
        {
          "command": "edoTensei.refreshIde",
          "when": "view == sessionHandoffView && viewItem == ideParentItem",
          "group": "ide@1"
        },
        {
          "command": "edoTensei.copyHandoffPrompt",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "inline@1"
        },
        {
          "command": "edoTensei.copyRawPath",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "inline@2"
        },
        {
          "command": "edoTensei.exportSession",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "inline@3"
        },
        {
          "command": "edoTensei.previewRawSession",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "session@1"
        },
        {
          "command": "edoTensei.exportSession",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "session@2"
        },
        {
          "command": "edoTensei.copyReferencePrompt",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "session@3"
        },
        {
          "command": "edoTensei.copyContextPrompt",
          "when": "view == sessionHandoffView && viewItem == sessionItem",
          "group": "session@4"
        }
      ]
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "vscode:prepublish": "npm run build:ext && npm run build:mcp",
    "build:ext": "esbuild src/extension.ts --bundle --minify --platform=node --target=node18 --format=cjs --outfile=dist/extension.js --external:vscode",
    "build:mcp": "esbuild mcp-server/src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/mcp/index.js --external:vscode",
    "build:mcp:watch": "esbuild mcp-server/src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/mcp/index.js --external:vscode --watch",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/extension.js --external:vscode --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "@types/vscode": "^1.79.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
